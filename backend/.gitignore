node_modules/
dist/
.env

# Per-chatbot learned notes (entity nicknames, etc.)
data/memory/*
!data/memory/.gitkeep

# Scheduled tasks (reminders, daily jobs)
data/scheduler/*
!data/scheduler/.gitkeep

# Gemini CLI job state
data/jobs/*
!data/jobs/.gitkeep

# Async shell job output
data/shell-jobs/*
!data/shell-jobs/.gitkeep

# Scan temp files (PDFs, page images)
data/scan/*
!data/scan/.gitkeep

# WhatsApp Baileys auth (session credentials)
data/whatsapp-auth/

# Persisted chat sessions (survives restart)
data/chat-sessions/
!data/chat-sessions/.gitkeep

# Cloned external repos (git clone workspace)
data/repos/
!data/repos/.gitkeep

# Single-instance lock (runtime, not committed)
data/.maikbot.lock
