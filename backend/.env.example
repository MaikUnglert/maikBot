# Telegram
TELEGRAM_BOT_TOKEN=replace_with_bot_token
ALLOWED_TELEGRAM_USER_IDS=123456789
TELEGRAM_ALLOW_EMPTY_ALLOWLIST=false

# Ollama (only reachable in local/proxmox network)
OLLAMA_BASE_URL=http://192.168.1.100:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_MS=180000
OLLAMA_MAX_TOOL_CALLS=10

# Multi-MCP configuration (preferred)
# Example:
# MCP_SERVERS_JSON=[{"name":"home_assistant","baseUrl":"http://192.168.178.87:8123","apiKey":"<HA_TOKEN>"},{"name":"paperless","baseUrl":"http://192.168.178.88:3000","apiKey":"<PAPERLESS_TOKEN>"}]
MCP_SERVERS_JSON=
# Optional policy (mcphost-like filtering/guardrails)
# Example:
# MCP_TOOL_POLICY_JSON={"default":{"excludedTools":["DangerousTool"]},"servers":{"home_assistant":{"requireExplicitPrefixTools":["HassTurnOff"]}}}
MCP_TOOL_POLICY_JSON=
MCP_TIMEOUT_MS=15000

# Legacy single-server fallback (used only when MCP_SERVERS_JSON is empty)
HA_MCP_BASE_URL=http://192.168.178.87:8123
HA_MCP_API_KEY=replace_with_home_assistant_long_lived_token

# Shell tool
SHELL_TIMEOUT_MS=30000

# Runtime
LOG_LEVEL=info
