# Telegram
TELEGRAM_BOT_TOKEN=replace_with_bot_token
ALLOWED_TELEGRAM_USER_IDS=123456789

# Ollama (only reachable in local/proxmox network)
OLLAMA_BASE_URL=http://192.168.1.100:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_MS=60000

# Home Assistant MCP Gateway (optional but recommended)
# Example: small local gateway that exposes one authenticated endpoint for MCP tool calls
HA_MCP_BASE_URL=http://127.0.0.1:8787
HA_MCP_API_KEY=replace_with_strong_key
HA_MCP_TOOL_NAME=home_assistant

# Runtime
LOG_LEVEL=info
