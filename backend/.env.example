# Telegram
TELEGRAM_BOT_TOKEN=replace_with_bot_token
ALLOWED_TELEGRAM_USER_IDS=123456789
TELEGRAM_ALLOW_EMPTY_ALLOWLIST=false

# WhatsApp (Baileys/WhatsApp Web) - optional second channel
WHATSAPP_ENABLED=false
# WHATSAPP_AUTH_DIR= (default: data/whatsapp-auth)
# Comma-separated E.164 numbers, e.g. +491234567890, or * for open
WHATSAPP_ALLOWED_FROM=
WHATSAPP_ALLOW_EMPTY_ALLOWLIST=false
WHATSAPP_PRINT_QR=true
WHATSAPP_GROUPS_ENABLED=false
# Only process "Message to yourself"; ignore all other senders
WHATSAPP_SELF_ONLY=false

# LLM Provider: "ollama", "gemini", or "nvidia" (switch at runtime via /model command)
LLM_PROVIDER=gemini
# Fewer API calls: skip triage (one less LLM call per message; larger tool set each time)
LLM_SKIP_TRIAGE=false
# Typical on/off phrasing (e.g. "turn X on", "mach Lampe an") skips triage → search+control only
LLM_HA_FAST_PATH=true

# Ollama (local, only reachable in local/proxmox network)
OLLAMA_BASE_URL=http://192.168.1.100:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_MS=300000

# Gemini (cloud, fast, free tier available)
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=300000

# NVIDIA NIM (https://build.nvidia.com — use with LLM_PROVIDER=nvidia)
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2.5
NVIDIA_MAX_TOKENS=16384
NVIDIA_TIMEOUT_MS=300000
# On HTTP 429: extra retries; fixed delay (ms) before each retry
NVIDIA_429_MAX_RETRIES=3
NVIDIA_429_BACKOFF_MS=1000

# Multi-MCP configuration (optional; bot starts without MCP if invalid)
# Direct URL (e.g. ha-mcp): [{"name":"home_assistant","url":"http://host:port/path"}]
# HA with token: [{"name":"home_assistant","baseUrl":"http://192.168.178.87:8123","apiKey":"<HA_TOKEN>"}]
MCP_SERVERS_JSON=
# Optional policy: exclude specific tools (two-phase routing handles selection)
# Example: MCP_TOOL_POLICY_JSON={"default":{"excludedTools":["ha_restart"]}}
MCP_TOOL_POLICY_JSON=
MCP_TIMEOUT_MS=15000

# Legacy single-server fallback (used only when MCP_SERVERS_JSON is empty)
HA_MCP_BASE_URL=http://192.168.178.87:8123
HA_MCP_API_KEY=replace_with_home_assistant_long_lived_token

# Persistent agent memory (Markdown: data/memory/<domain>.md from process cwd; override path if needed)
MEMORY_DATA_DIR=

# Browser automation (Playwright, isolated headless Chromium)
BROWSER_ENABLED=false
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
# Vision for browser_screenshot_analyze: Gemini (if GEMINI_API_KEY) or Ollama (OLLAMA_VISION_MODEL)
# OLLAMA_VISION_MODEL=llava

# Tool limits (LLM_MAX_TOOL_CALLS=0 means unlimited)
LLM_MAX_TOOL_CALLS=0
SHELL_TIMEOUT_MS=30000

# Heartbeat: adaptive intervals. Active when tasks due or Gemini running; idle when nothing to do.
HEARTBEAT_ACTIVE_INTERVAL_SEC=60
HEARTBEAT_IDLE_INTERVAL_SEC=1800
# SCHEDULER_DATA_DIR= (default: data/scheduler)

# Gemini CLI delegation (requires gemini CLI installed and configured)
# JOBS_DATA_DIR= (default: data/jobs)
# GEMINI_CLI_WORKSPACE_ROOT= (default: process.cwd())

# Chat context: max age in ms before session is pruned. 24h default for long-running Gemini CLI jobs.
# CHAT_MAX_AGE_MS=86400000

# Runtime
LOG_LEVEL=info
