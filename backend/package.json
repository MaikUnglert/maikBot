{
  "name": "maikbot-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Secure local assistant bridge: Telegram -> Ollama + Home Assistant MCP",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:ollama:reachability": "tsx src/tests/ollama-reachability.test.ts",
    "test:ollama:chat": "tsx src/tests/ollama-chat.test.ts",
    "test:ha:reachability": "tsx src/tests/ha-reachability.test.ts",
    "test:ha:mcp-tools": "tsx src/tests/ha-mcp-tools.test.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "node-telegram-bot-api": "^0.66.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/node-telegram-bot-api": "^0.64.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
